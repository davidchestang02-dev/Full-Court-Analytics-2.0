{
  "name": "Full Court Analytics",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",

  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "app/fca_app.py",
        "app/ui/data_access.py",
        "app/ui/components.py",
        "app/ui/styles.py"
      ]
    },
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "files.trimTrailingWhitespace": true,
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  "updateContentCommand": "if [ -f packages.txt ]; then sudo apt update && sudo xargs -a packages.txt apt install -y; fi && if [ -f requirements.txt ]; then pip3 install --user -r requirements.txt; fi && pip3 install --user streamlit && echo '\\u2705 Dev container ready'",

  "postAttachCommand": {
    "server": "streamlit run app/fca_app.py --server.enableCORS false --server.enableXsrfProtection false"
  },

  "portsAttributes": {
    "8501": {
      "label": "Full Court Analytics",
      "onAutoForward": "openPreview"
    }
  },

  "forwardPorts": [8501]
}
